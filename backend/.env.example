# Single-user password to log in to the dashboard
APP_PASSWORD=changeme

# Random secret for signing session cookies and rotation tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me-with-a-long-random-string

# Public base URL of the app (used in email links).
# In local dev: http://localhost:5173
# In prod: https://keyrotate.yourdomain.com
APP_BASE_URL=http://localhost:5173

# Where the backend serves the rotation form (often same host as APP_BASE_URL behind a proxy,
# or the raw backend URL in dev).
BACKEND_BASE_URL=http://localhost:8000

# Resend API key (optional — if unset, emails are logged to console instead of sent)
# Sign up at https://resend.com — 3000 emails/month free.
RESEND_API_KEY=
RESEND_FROM=KeyRotate <onboarding@resend.dev>
NOTIFY_EMAIL=you@example.com

# Optional Slack incoming webhook for notifications
SLACK_WEBHOOK_URL=

# Daily cron hour (24h, local time of the server)
CRON_HOUR=9
